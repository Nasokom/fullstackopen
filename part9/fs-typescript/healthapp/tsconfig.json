{
    "compilerOptions": {
    "noImplicitAny": true,
    "noEmit": true,
    "types": ["node","express"],
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "module": "nodenext",
    "esModuleInterop": true,
    "allowImportingTsExtensions": true
    }
}